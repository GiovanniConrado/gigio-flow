# Gigio Flow Studio environment
# Copy this file to .env and fill only the values you need.

# Local backend port
PORT=3001

# Linear integration, optional
# Create a personal API key at https://linear.app/settings/api
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_WEBHOOK_SECRET=

# GitHub integration, planned
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Vercel integration, planned
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
